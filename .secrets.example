# Lalabuba deploy credentials — copy to .secrets (gitignored) and fill in.
# Sourced by scripts/deploy.sh. Prefer 1Password/Bitwarden CLI injection over a
# plaintext file; until then keep this file chmod 600 and NEVER commit it.

# ── Server / SSH ───────────────────────────────────────────────────────────────
HETZNER_HOST=91.99.212.17
HETZNER_USER=deploy            # non-root deploy user (provisioned during migration)
HETZNER_SSH_KEY=~/.ssh/id_rsa  # key with access to the server
GITHUB_SSH_KEY=~/.ssh/id_ed25519_github  # dedicated GitHub push key (NOT the server key)

# ── Cloudflare (DNS + SSL automation) ──────────────────────────────────────────
# Token scoped to lalabuba.com: Zone:DNS:Edit + Zone:SSL and Certificates:Edit + Zone:Zone:Read
CF_API_TOKEN=
CF_ZONE=lalabuba.com

# ── Runtime app secrets → pushed to Docker Swarm as lalabuba_{env}_<NAME> ───────
# Provide _PROD and _DEV variants. Empty values are skipped (not created).
IMAGE_PROVIDER_PROD=huggingface
IMAGE_PROVIDER_DEV=huggingface
HF_TOKEN_PROD=
HF_TOKEN_DEV=
TOGETHER_API_KEY_PROD=
TOGETHER_API_KEY_DEV=
NOVITA_API_KEY_PROD=
NOVITA_API_KEY_DEV=
TURNSTILE_SECRET_KEY_PROD=
TURNSTILE_SECRET_KEY_DEV=
APP_API_KEY_PROD=
APP_API_KEY_DEV=
RESEND_API_KEY_PROD=
RESEND_API_KEY_DEV=
# DATABASE_URL_{PROD,DEV} are already provisioned as Swarm secrets on the server.
