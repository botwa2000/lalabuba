{
  "version": 2,
  "builds": [
    { "src": "api/generate-image.js", "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "public/**",             "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate-image", "dest": "/api/generate-image.js" },
    { "src": "/(.*)",               "dest": "/public/$1" }
  ],
  "headers": [
    { "source": "/(.*)\.html", "headers": [{ "key": "Cache-Control", "value": "no-store" }] },
    { "source": "/(.*)\.css",  "headers": [{ "key": "Cache-Control", "value": "no-store" }] },
    { "source": "/(.*)\.js",   "headers": [{ "key": "Cache-Control", "value": "no-store" }] }
  ]
}
