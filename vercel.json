{
  "version": 2,
  "builds": [
    { "src": "api/generate-image.js", "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/contact.js",        "use": "@vercel/node", "config": { "maxDuration": 10 } },
    { "src": "public/**",             "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*)\\.(png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf)", "headers": { "Cache-Control": "public, max-age=2592000" }, "continue": true },
    { "src": "/(.*)\\.(css|js)", "headers": { "Cache-Control": "public, max-age=86400, must-revalidate" }, "continue": true },
    { "src": "/(.*)\\.html", "headers": { "Cache-Control": "public, max-age=0, must-revalidate" }, "continue": true },
    { "src": "/api/generate-image", "dest": "/api/generate-image.js" },
    { "src": "/api/contact",        "dest": "/api/contact.js" },
    { "src": "/privacy",            "dest": "/public/privacy.html" },
    { "src": "/terms",              "dest": "/public/terms.html" },
    { "src": "/impressum",          "dest": "/public/impressum.html" },
    { "src": "/contact",            "dest": "/public/contact.html" },
    { "src": "/features",           "dest": "/public/features.html" },
    { "src": "/about",              "dest": "/public/about.html" },
    { "src": "/coloring-pages",     "dest": "/public/coloring-pages/index.html" },
    { "src": "/coloring-pages/dragon",    "dest": "/public/coloring-pages/dragon/index.html" },
    { "src": "/coloring-pages/unicorn",   "dest": "/public/coloring-pages/unicorn/index.html" },
    { "src": "/coloring-pages/butterfly", "dest": "/public/coloring-pages/butterfly/index.html" },
    { "src": "/coloring-pages/dinosaur",  "dest": "/public/coloring-pages/dinosaur/index.html" },
    { "src": "/coloring-pages/cat",       "dest": "/public/coloring-pages/cat/index.html" },
    { "src": "/coloring-pages/princess",  "dest": "/public/coloring-pages/princess/index.html" },
    { "src": "/coloring-pages/mermaid",   "dest": "/public/coloring-pages/mermaid/index.html" },
    { "src": "/coloring-pages/rocket",    "dest": "/public/coloring-pages/rocket/index.html" },
    { "src": "/(.*)",               "dest": "/public/$1" }
  ]
}
