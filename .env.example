# Image provider: kept for reference, waterfall is now automatic
IMAGE_PROVIDER=huggingface

# Hugging Face API token (legacy fallback) — https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Optional: override the default FLUX model
# HF_MODEL=black-forest-labs/FLUX.1-schnell

# Vercel Blob — enables instant image sharing via QR code (no re-generation).
# 1. Go to your Vercel project → Storage → Create a Blob store
# 2. Copy the BLOB_READ_WRITE_TOKEN and paste it here (and add it in Vercel env vars)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ── AI provider waterfall (Tier 2–4) ─────────────────────────────────────────
# Each tier is skipped if its key is absent. Only Tier 4 (Novita) costs money.
# See GUIDES.md Part 3 for sign-up steps and cost details.

# Tier 2: Together AI — free ~10 000 imgs/month
# Sign up: https://api.together.ai
# TOGETHER_API_KEY=your_key_here

# Tier 3: Cloudflare Workers AI — free ~35 imgs/day, ~$0.003/img overage
# Account ID: dash.cloudflare.com → right sidebar
# API Token:  dash.cloudflare.com → My Profile → API Tokens → Create Token
#   → Use template "Workers AI" or custom with permission: Account > Workers AI > Edit
# CF_ACCOUNT_ID=your_32char_account_id
# CF_API_TOKEN=your_token_here

# Tier 4: Novita.ai — paid ~$0.001–$0.003/img (cheapest fallback)
# Sign up: https://novita.ai
# NOVITA_API_KEY=your_key_here
